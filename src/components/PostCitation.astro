---
import { SITE } from "@/config";
import {
  buildBibtexCitation,
  buildHumanCitation,
} from "@/utils/citation";

type Props = {
  author: string;
  title: string;
  pubDatetime: Date;
  url: string;
  slug: string;
  lang?: string;
  timeZone?: string;
};

const {
  author,
  title,
  pubDatetime,
  url,
  slug,
  lang = SITE.lang ?? "en",
  timeZone = SITE.timezone,
} = Astro.props;

const bibtex = buildBibtexCitation({
  author,
  title,
  url,
  pubDatetime,
  slug,
  lang,
  timeZone,
});
const plainCitation = buildHumanCitation({
  author,
  title,
  url,
  pubDatetime,
  lang,
  timeZone,
});
const citationSuffix = `${url}.`;
const plainCitationPrefix = plainCitation.endsWith(citationSuffix)
  ? plainCitation.slice(0, -citationSuffix.length).trimEnd()
  : plainCitation;
---

<section
  id="citation"
  class="post-citation mt-10 rounded-lg border border-border bg-muted/20 p-4 sm:p-5"
  data-pagefind-ignore
>
  <h2 class="text-lg font-semibold text-foreground">Citation</h2>

  <div class="mt-3 rounded-md border border-border bg-background">
    <pre
      class="overflow-x-auto p-4 text-xs leading-relaxed sm:text-sm"
    ><code>{bibtex}</code></pre>
  </div>

  <p class="mt-4 text-sm text-foreground/70">
    For attribution, please cite this work as:
  </p>
  <p class="mt-2 rounded-md border border-border bg-background px-3 py-2 text-sm leading-relaxed text-foreground/90">
    {plainCitationPrefix}
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      data-external-link
      class="mt-1 block break-all text-accent decoration-dashed underline-offset-4"
      >{url}</a
    >
  </p>
</section>
