---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import ReadingStats from "./ReadingStats.astro";

type Props = {
  variant?: "h2" | "h3";
  dateLayout?: "right" | "below-title";
  showDate?: boolean;
  showReadingStats?: boolean;
} & CollectionEntry<"blog">;

const {
  variant: Heading = "h2",
  dateLayout = "right",
  showDate = true,
  showReadingStats = true,
  id,
  data,
  filePath,
  body,
} = Astro.props;

const { title, description, draft = false, ...props } = data;
---

<li class="my-6">
  <div
    class:list={[
      "grid grid-cols-1 gap-y-1",
      {
        "sm:grid-cols-[minmax(0,1fr)_12rem] sm:gap-x-4":
          showDate && dateLayout === "right",
      },
    ]}
  >
    <a
      href={getPath(id, filePath)}
      class:list={[
        "min-w-0 text-lg font-medium text-accent",
        "decoration-dashed underline-offset-4 hover:underline",
        "focus-visible:no-underline focus-visible:underline-offset-0",
      ]}
    >
      <Heading
        class="m-0 min-w-0 leading-tight"
        style={{
          viewTransitionName: "heading" + slugifyStr(title.replaceAll(".", "-")),
        }}
      >
        <span>{title}</span>
        {
          draft && (
            <span class="post-status-badge post-status-badge--draft ml-2">
              Draft
            </span>
          )
        }
      </Heading>
    </a>
    {showDate && (
      <Datetime
        {...props}
        class:list={[
          "shrink-0",
          {
            "sm:justify-start": dateLayout === "right",
          },
        ]}
        style={{
          viewTransitionName: "date" + slugifyStr(title.replaceAll(".", "-")),
        }}
      />
    )}
    {showReadingStats && (
      <ReadingStats
        {body}
        class:list={[
          "mt-1",
          { "sm:col-span-2": showDate && dateLayout === "right" },
        ]}
        align="center"
      />
    )}
    <p
      class:list={[
        "mt-1",
        { "sm:col-span-2": showDate && dateLayout === "right" },
      ]}
    >
      {description}
    </p>
  </div>
</li>
