---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { SITE } from "@/config";
import { getRepositoryHeadCommitHash } from "@/utils/getLatestCommitHash";

const currentYear = new Date().getFullYear();
const buildDate = new Date();
const buildIsoString = buildDate.toISOString();
const buildTimeFallbackLabel = new Intl.DateTimeFormat("en-US", {
  dateStyle: "medium",
  timeStyle: "short",
  timeZone: "UTC",
}).format(buildDate);
const latestCommitHash = SITE.sourceCommit.enabled
  ? getRepositoryHeadCommitHash()
  : undefined;

const toCommitBaseUrl = (sourceUrl: string): string => {
  const trimmedUrl = sourceUrl.trim();
  if (trimmedUrl === "") return "";
  if (trimmedUrl.includes("/blob/")) {
    return trimmedUrl.replace(/\/blob\/?$/, "/commit/");
  }
  if (trimmedUrl.includes("/tree/")) {
    return trimmedUrl.replace(/\/tree\/?$/, "/commit/");
  }
  return trimmedUrl.endsWith("/")
    ? `${trimmedUrl}commit/`
    : `${trimmedUrl}/commit/`;
};

const latestCommitHref =
  SITE.sourceCommit.enabled &&
  latestCommitHash &&
  SITE.sourceCommit.url.trim() !== ""
    ? `${toCommitBaseUrl(SITE.sourceCommit.url)}${latestCommitHash}`
    : undefined;

const latestCommitTitle = latestCommitHash
  ? `View latest commit: ${latestCommitHash.slice(0, 7)}`
  : undefined;

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "py-6 sm:py-4",
      "border-t border-border",
      "flex flex-col items-center gap-2 sm:grid sm:grid-cols-[1fr_auto_1fr] sm:items-center",
    ]}
  >
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:justify-self-start sm:flex-row">
      <span>
        &#169;{" "}
        {
          latestCommitHref ? (
            <a
              href={latestCommitHref}
              target="_blank"
              rel="noopener noreferrer"
              title={latestCommitTitle}
              class="underline decoration-dashed underline-offset-4 hover:text-accent"
            >
              {currentYear}
            </a>
          ) : (
            currentYear
          )
        }
      </span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>
        <a
          href={SITE.license.url}
          rel="license noopener noreferrer"
          target="_blank"
          data-external-link
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
        >
          {SITE.license.name}
        </a>
      </span>
    </div>
    <time
      class="text-[0.7rem] uppercase tracking-[0.08em] text-foreground/45 sm:justify-self-center"
      data-build-local-time
      data-build-iso={buildIsoString}
      datetime={buildIsoString}
      title={buildIsoString}
    >
      {buildTimeFallbackLabel} UTC
    </time>
    <div class="sm:justify-self-end">
      <Socials />
    </div>
  </div>
  <p class="mx-auto mb-8 max-w-3xl text-center text-xs leading-relaxed text-foreground/60">
    All views or opinions expressed here are solely mine and are not represented,
    shared, supported, or endorsed by any employer or entity in any manner.
  </p>
</footer>

<script>
  const hydrateBuildTimestamp = (root: ParentNode = document): void => {
    const elements =
      root.querySelectorAll<HTMLElement>("time[data-build-local-time]");

    for (const element of elements) {
      const isoString = element.dataset.buildIso;
      if (!isoString) continue;

      const date = new Date(isoString);
      if (Number.isNaN(date.getTime())) continue;

      const localTimeLabel = new Intl.DateTimeFormat(undefined, {
        dateStyle: "medium",
        timeStyle: "short",
      }).format(date);

      element.textContent = localTimeLabel;
      element.title = date.toString();
    }
  };

  const setBuildTimestamp = (): void => {
    hydrateBuildTimestamp(document);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setBuildTimestamp, {
      once: true,
    });
  } else {
    setBuildTimestamp();
  }

  document.addEventListener("astro:page-load", setBuildTimestamp);
</script>
