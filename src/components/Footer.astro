---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { SITE } from "@/config";
import { getRepositoryHeadCommitHash } from "@/utils/getLatestCommitHash";

const currentYear = new Date().getFullYear();
const buildDate = new Date();
const buildIsoString = buildDate.toISOString();
const buildTimestampLabel = buildIsoString.replace(/\.\d{3}Z$/, "Z");
const latestCommitHash = SITE.sourceCommit.enabled
  ? getRepositoryHeadCommitHash()
  : undefined;

const toTreeBaseUrl = (sourceUrl: string): string => {
  const trimmedUrl = sourceUrl.trim();
  if (trimmedUrl === "") return "";

  if (trimmedUrl.includes("/tree/")) {
    return trimmedUrl.replace(/\/tree\/?$/, "/tree/");
  }

  if (trimmedUrl.includes("/blob/")) {
    return trimmedUrl.replace(/\/blob\/?$/, "/tree/");
  }

  if (trimmedUrl.includes("/commit/")) {
    return trimmedUrl.replace(/\/commit\/?$/, "/tree/");
  }

  return trimmedUrl.endsWith("/")
    ? `${trimmedUrl}tree/`
    : `${trimmedUrl}/tree/`;
};

const buildTreeRef = latestCommitHash ?? "main";
const buildTreeHref =
  SITE.sourceCommit.enabled && SITE.sourceCommit.url.trim() !== ""
    ? `${toTreeBaseUrl(SITE.sourceCommit.url)}${buildTreeRef}`
    : undefined;

const buildTreeTitle = latestCommitHash
  ? `View source tree: ${latestCommitHash.slice(0, 7)}`
  : "View source tree";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "py-6 sm:py-4",
      "border-t border-border",
      "flex flex-col items-center gap-2 sm:grid sm:grid-cols-[1fr_auto_1fr] sm:items-center",
    ]}
  >
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:justify-self-start sm:flex-row">
      <span>&#169; {currentYear}</span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>
        <a
          href={SITE.license.url}
          rel="license noopener noreferrer"
          target="_blank"
          data-external-link
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
        >
          {SITE.license.name}
        </a>
      </span>
    </div>
    {
      buildTreeHref ? (
        <a
          href={buildTreeHref}
          target="_blank"
          rel="noopener noreferrer"
          title={buildTreeTitle}
          class="sm:justify-self-center text-foreground/45 transition-colors hover:text-foreground/60"
        >
          <time
            class="text-[0.7rem] tracking-[0.08em]"
            data-build-local-time
            data-build-iso={buildIsoString}
            datetime={buildIsoString}
            title={buildIsoString}
          >
            {buildTimestampLabel}
          </time>
        </a>
      ) : (
        <time
          class="text-[0.7rem] tracking-[0.08em] text-foreground/45 sm:justify-self-center"
          data-build-local-time
          data-build-iso={buildIsoString}
          datetime={buildIsoString}
          title={buildIsoString}
        >
          {buildTimestampLabel}
        </time>
      )
    }
    <div class="sm:justify-self-end">
      <Socials />
    </div>
  </div>
  <p class="mx-auto mb-8 max-w-3xl text-center text-xs leading-relaxed text-foreground/60">
    All views or opinions expressed here are solely mine and are not represented,
    shared, supported, or endorsed by any employer or entity in any manner.
  </p>
</footer>

<script>
  const pad2 = (value: number): string => String(value).padStart(2, "0");

  const formatOffset = (offsetMinutes: number): string => {
    const sign = offsetMinutes <= 0 ? "+" : "-";
    const absoluteMinutes = Math.abs(offsetMinutes);
    const hours = pad2(Math.floor(absoluteMinutes / 60));
    const minutes = pad2(absoluteMinutes % 60);
    return `${sign}${hours}:${minutes}`;
  };

  const formatLocalTimestamp = (date: Date): string => {
    const year = date.getFullYear();
    const month = pad2(date.getMonth() + 1);
    const day = pad2(date.getDate());
    const hours = pad2(date.getHours());
    const minutes = pad2(date.getMinutes());
    const seconds = pad2(date.getSeconds());
    const offset = formatOffset(date.getTimezoneOffset());

    return `${year}-${month}-${day}T${hours}:${minutes}:${seconds}${offset}`;
  };

  const hydrateBuildTimestamp = (root: ParentNode = document): void => {
    const elements =
      root.querySelectorAll<HTMLElement>("time[data-build-local-time]");

    for (const element of elements) {
      const isoString = element.dataset.buildIso;
      if (!isoString) continue;

      const date = new Date(isoString);
      if (Number.isNaN(date.getTime())) continue;

      element.textContent = formatLocalTimestamp(date);
      element.title = isoString;
    }
  };

  const setBuildTimestamp = (): void => {
    hydrateBuildTimestamp(document);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setBuildTimestamp, {
      once: true,
    });
  } else {
    setBuildTimestamp();
  }

  document.addEventListener("astro:page-load", setBuildTimestamp);
</script>
