---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import ReadingStats from "@/components/ReadingStats.astro";
import PostCitation from "@/components/PostCitation.astro";
import { Icon } from "astro-icon/components";
import { getPath } from "@/utils/getPath";
import { getLatestCommitHash } from "@/utils/getLatestCommitHash";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
  hideCitation = false,
  toc = true,
  notebookPath,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Resolve OG image URL from frontmatter only.
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const sourcePath = post.filePath;
const sourceCommitHash = SITE.sourceCommit.enabled
  ? getLatestCommitHash(sourcePath)
  : undefined;
const sourceRef = sourceCommitHash ?? "main";
const sourceCommitHref =
  SITE.sourceCommit.enabled && sourcePath && SITE.sourceCommit.url.trim() !== ""
    ? `${SITE.sourceCommit.url}${sourceRef}/${sourcePath}`
    : undefined;
const sourceCommitTitle =
  SITE.sourceCommit.enabled && sourcePath
    ? sourceCommitHash
      ? `${SITE.sourceCommit.text}: ${sourceCommitHash.slice(0, 7)}`
      : `${SITE.sourceCommit.text}: latest`
    : undefined;
const showPostActions =
  !hideEditPost &&
  (SITE.editPost.enabled || (SITE.notebookView.enabled && !!notebookPath));
const hasStickyToc = toc;
const pagefindDate = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
  timeZone: timezone || SITE.timezone,
}).format(new Date(pubDatetime));
const postUrl = canonicalURL
  ? new URL(canonicalURL, SITE.website).href
  : new URL(getPath(post.id, post.filePath), SITE.website).href;

const layoutProps = {
  title: `${title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;
---

<Layout {...layoutProps}>
  <Header />
  <main id="main-content" class="app-layout pb-12" data-pagefind-body>
    <span class="sr-only" data-pagefind-meta="date">{pagefindDate}</span>
    <div class="mt-8 flex items-center gap-2 sm:relative sm:block">
      <BackButton class="sm:absolute sm:top-1/2 sm:left-0 sm:-translate-y-1/2 sm:-translate-x-[calc(100%+0.5rem)]" />
      <h1
        transition:name={"heading" + slugifyStr(title.replaceAll(".", "-"))}
        class="min-w-0 text-2xl font-bold text-accent sm:text-3xl"
      >
        {title}
      </h1>
    </div>
    <div class="my-2 flex items-center gap-2">
      <Datetime
        {pubDatetime}
        {modDatetime}
        {timezone}
        href={sourceCommitHref}
        linkTitle={sourceCommitTitle}
        size="lg"
        style={{
          viewTransitionName: "date" + slugifyStr(title.replaceAll(".", "-")),
        }}
      />
      <div class="flex flex-1 items-center gap-4">
        <ReadingStats body={post.body} size="lg" align="center" class="flex-1" />
        <div
          class:list={[
            "ml-auto max-sm:hidden",
            { hidden: !showPostActions },
          ]}
        >
          <EditPost {hideEditPost} {post} />
        </div>
      </div>
    </div>
    <article
      id="article"
      class:list={[
        "app-prose drop-cap-lead mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)",
        {
          "has-sticky-toc": hasStickyToc,
        },
      ]}
    >
      <Content />
    </article>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    {
      !hideCitation && (
        <PostCitation
          {author}
          {title}
          {pubDatetime}
          url={postUrl}
          slug={post.id}
          timeZone={timezone || SITE.timezone}
        />
      )
    }

    <div
      class="mt-10 mb-6 grid items-start gap-6 md:grid-cols-[1fr_auto_1fr]"
      data-pagefind-ignore
    >
      <div class="justify-self-center md:justify-self-start">
        <ShareLinks />
      </div>

      <ul class="flex flex-wrap items-center justify-center gap-4 self-center">
        {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
      </ul>

      <div class="justify-self-center md:justify-self-end">
        <BackToTopButton />
      </div>
    </div>

    <div class="giscus"></div>

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="flex w-full items-center gap-2 hover:opacity-75"
          >
            <Icon
              name="tabler:chevron-left"
              class="inline-block size-6 flex-none self-center rtl:rotate-180"
            />
            <div>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="flex w-full items-center justify-end gap-2 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <Icon
              name="tabler:chevron-right"
              class="inline-block size-6 flex-none self-center rtl:rotate-180"
            />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    if (document.getElementById("progress-container")) return;

    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.id = "progress-container";
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    if (window.__kdPostScrollProgressBound) return;
    window.__kdPostScrollProgressBound = true;

    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }

  /**
   * Keeps TOC docked to the left on large screens.
   */
  function setupDockingToc() {
    const article = document.getElementById("article");
    if (!article || !article.classList.contains("has-sticky-toc")) return;

    const contentHeadings = Array.from(
      article.querySelectorAll("h2, h3, h4, h5, h6")
    ).filter(
      heading =>
        heading instanceof HTMLHeadingElement &&
        heading.id &&
        heading.id !== "table-of-contents"
    );
    if (!contentHeadings.length) return;

    const tocHeading = article.querySelector("h2#table-of-contents");
    const tocList = tocHeading?.nextElementSibling;

    if (
      !(tocHeading instanceof HTMLHeadingElement) ||
      !(tocList instanceof HTMLElement) ||
      !["UL", "OL"].includes(tocList.tagName)
    ) {
      return;
    }

    let floatingToc = tocHeading.closest(".inline-toc-floating");
    let placeholder = floatingToc?.previousElementSibling;

    if (!floatingToc) {
      floatingToc = document.createElement("div");
      floatingToc.className = "inline-toc-floating";

      placeholder = document.createElement("div");
      placeholder.className = "inline-toc-placeholder";
      placeholder.hidden = true;

      tocHeading.before(placeholder);
      tocHeading.before(floatingToc);
      floatingToc.appendChild(tocHeading);
      floatingToc.appendChild(tocList);
    }

    if (!(placeholder instanceof HTMLElement)) return;

    const getHeadingHtml = heading => {
      const clone = heading.cloneNode(true);
      if (!(clone instanceof HTMLElement)) {
        return "";
      }

      clone.querySelectorAll(".heading-link").forEach(link => link.remove());
      return clone.innerHTML.trim();
    };

    const getHeadingLabel = heading => {
      const clone = heading.cloneNode(true);
      if (!(clone instanceof HTMLElement)) {
        return heading.textContent?.trim() ?? "";
      }

      clone.querySelectorAll(".heading-link").forEach(link => link.remove());
      return clone.textContent?.trim() ?? "";
    };

    const ensureTocHeadingLink = heading => {
      if (!(heading instanceof HTMLHeadingElement) || !heading.id) return;
      const headingHash = `#${heading.id}`;

      const hasLink = Array.from(
        tocList.querySelectorAll("a[href^='#']")
      ).some(link => link.getAttribute("href") === headingHash);
      if (hasLink) return;

      const label = getHeadingLabel(heading);
      if (!label) return;

      const item = document.createElement("li");
      const link = document.createElement("a");
      link.href = headingHash;
      const headingHtml = getHeadingHtml(heading);
      if (headingHtml) {
        link.innerHTML = headingHtml;
      } else {
        link.textContent = label;
      }
      item.appendChild(link);
      tocList.appendChild(item);
    };

    const footnotesSection = article.querySelector("section[data-footnotes]");
    if (footnotesSection instanceof HTMLElement) {
      const footnotesHeading = footnotesSection.querySelector(
        "h2[id], h3[id], h4[id], h5[id], h6[id]"
      );
      ensureTocHeadingLink(footnotesHeading);
    }

    const referencesRoot = article.querySelector("#refs");
    if (referencesRoot instanceof HTMLElement) {
      let referencesHeading = referencesRoot.previousElementSibling;
      while (
        referencesHeading &&
        !(referencesHeading instanceof HTMLHeadingElement)
      ) {
        referencesHeading = referencesHeading.previousElementSibling;
      }
      ensureTocHeadingLink(referencesHeading);
    }

    const tocLinks = Array.from(
      tocList.querySelectorAll("a[href^='#']")
    ).filter(link => link instanceof HTMLAnchorElement);

    const headingEntries = tocLinks
      .map(link => {
        const hash = link.getAttribute("href");
        if (!hash || hash === "#") return null;

        let headingId = hash.slice(1);
        try {
          headingId = decodeURIComponent(headingId);
        } catch {
          // Keep original hash if decoding fails.
        }

        const heading = document.getElementById(headingId);
        if (!heading || !article.contains(heading)) return null;

        const headingHtml = getHeadingHtml(heading);
        if (headingHtml && link.innerHTML.trim() !== headingHtml) {
          link.innerHTML = headingHtml;
        }

        link.classList.add("toc-link");

        return {
          link,
          heading,
          pathStart: 0,
          pathEnd: 0,
          isIntersecting: false,
        };
      })
      .filter(Boolean);

    const svgNamespace = "http://www.w3.org/2000/svg";
    let tocProgressSvg = floatingToc.querySelector(".inline-toc-progress");
    if (!(tocProgressSvg instanceof SVGSVGElement)) {
      tocProgressSvg = document.createElementNS(svgNamespace, "svg");
      tocProgressSvg.setAttribute("class", "inline-toc-progress");
      tocProgressSvg.setAttribute("aria-hidden", "true");
      floatingToc.appendChild(tocProgressSvg);
    } else {
      while (tocProgressSvg.firstChild) {
        tocProgressSvg.firstChild.remove();
      }
    }

    const tocProgressTrack = document.createElementNS(svgNamespace, "path");
    tocProgressTrack.setAttribute("class", "inline-toc-progress-track");
    tocProgressSvg.appendChild(tocProgressTrack);

    const tocProgressActive = document.createElementNS(svgNamespace, "path");
    tocProgressActive.setAttribute("class", "inline-toc-progress-active");
    tocProgressSvg.appendChild(tocProgressActive);

    let tocPathLength = 0;

    const rebuildTocProgressPath = () => {
      if (!headingEntries.length) {
        tocPathLength = 0;
        tocProgressTrack.setAttribute("d", "");
        tocProgressActive.setAttribute("d", "");
        tocProgressActive.classList.remove("is-visible");
        return;
      }

      const tocRect = floatingToc.getBoundingClientRect();
      let pathData = "";
      let previousX = 0;
      let maxX = 0;
      let maxY = 0;

      for (let index = 0; index < headingEntries.length; index += 1) {
        const entry = headingEntries[index];
        const linkRect = entry.link.getBoundingClientRect();
        const x = Math.max(4, linkRect.left - tocRect.left - 8);
        const y = Math.max(
          6,
          linkRect.top - tocRect.top + floatingToc.scrollTop - 2
        );
        const entryHeight = Math.max(16, linkRect.height + 4);

        if (index === 0) {
          pathData += `M ${x} ${y}`;
          entry.pathStart = 0;
        } else {
          pathData += ` V ${y}`;
          if (Math.abs(previousX - x) > 0.5) {
            pathData += ` H ${x}`;
          }
          tocProgressTrack.setAttribute("d", pathData);
          entry.pathStart = tocProgressTrack.getTotalLength();
        }

        pathData += ` V ${y + entryHeight}`;
        tocProgressTrack.setAttribute("d", pathData);
        entry.pathEnd = tocProgressTrack.getTotalLength();

        previousX = x;
        maxX = Math.max(maxX, x);
        maxY = Math.max(maxY, y + entryHeight);
      }

      tocProgressTrack.setAttribute("d", pathData);
      tocProgressActive.setAttribute("d", pathData);

      const svgWidth = Math.max(floatingToc.clientWidth, maxX + 16);
      const svgHeight = Math.max(floatingToc.scrollHeight, maxY + 12);
      tocProgressSvg.setAttribute("viewBox", `0 0 ${svgWidth} ${svgHeight}`);
      tocProgressSvg.style.width = `${svgWidth}px`;
      tocProgressSvg.style.height = `${svgHeight}px`;

      tocPathLength = tocProgressTrack.getTotalLength();
      if (tocPathLength > 0) {
        tocProgressActive.style.strokeDasharray = `1 ${tocPathLength}`;
        tocProgressActive.style.strokeDashoffset = "1";
      } else {
        tocProgressActive.style.strokeDasharray = "";
        tocProgressActive.style.strokeDashoffset = "";
      }
    };

    const updateVisibleProgressPath = activeEntry => {
      if (!tocPathLength || !headingEntries.length) {
        tocProgressActive.classList.remove("is-visible");
        return;
      }

      let pathStart = tocPathLength;
      let pathEnd = 0;

      for (const entry of headingEntries) {
        if (!entry.isIntersecting) continue;
        pathStart = Math.min(pathStart, entry.pathStart);
        pathEnd = Math.max(pathEnd, entry.pathEnd);
      }

      if (pathStart >= pathEnd && activeEntry) {
        pathStart = activeEntry.pathStart;
        pathEnd = activeEntry.pathEnd;
      }

      if (pathStart >= pathEnd) {
        tocProgressActive.style.strokeDasharray = `1 ${tocPathLength}`;
        tocProgressActive.classList.remove("is-visible");
        return;
      }

      const visibleLength = Math.max(1, pathEnd - pathStart);
      tocProgressActive.style.strokeDasharray =
        `1 ${pathStart} ${visibleLength} ${tocPathLength}`;
      tocProgressActive.style.strokeDashoffset = "1";
      tocProgressActive.classList.add("is-visible");
    };

    let activeTocLink = null;

    const setActiveTocLink = link => {
      if (activeTocLink === link) return false;

      if (activeTocLink) {
        activeTocLink.classList.remove("is-current-section");
      }

      activeTocLink = link;

      if (activeTocLink) {
        activeTocLink.classList.add("is-current-section");
      }

      return true;
    };

    const keepActiveLinkInView = link => {
      if (!(link instanceof HTMLElement)) return;
      if (floatingToc.scrollHeight <= floatingToc.clientHeight + 1) return;

      const tocRect = floatingToc.getBoundingClientRect();
      const linkRect = link.getBoundingClientRect();
      const linkTop =
        linkRect.top - tocRect.top + floatingToc.scrollTop;
      const linkBottom = linkTop + linkRect.height;
      const viewportTop = floatingToc.scrollTop;
      const viewportBottom = viewportTop + floatingToc.clientHeight;
      const margin = 18;

      const isAbove = linkTop < viewportTop + margin;
      const isBelow = linkBottom > viewportBottom - margin;
      if (!isAbove && !isBelow) return;

      const centeredTop = Math.max(
        0,
        Math.min(
          linkTop - (floatingToc.clientHeight - linkRect.height) / 2,
          floatingToc.scrollHeight - floatingToc.clientHeight
        )
      );

      floatingToc.scrollTo({
        top: centeredTop,
        behavior: "smooth",
      });
    };

    const updateActiveSection = () => {
      if (!headingEntries.length) {
        setActiveTocLink(null);
        updateVisibleProgressPath(null);
        return null;
      }

      const activationOffset = 144;
      let activeEntry = headingEntries[0];

      for (const entry of headingEntries) {
        if (entry.heading.getBoundingClientRect().top <= activationOffset) {
          activeEntry = entry;
        } else {
          break;
        }
      }

      const scrollBottom = window.scrollY + window.innerHeight;
      const pageBottom = document.documentElement.scrollHeight - 8;
      if (scrollBottom >= pageBottom) {
        activeEntry = headingEntries[headingEntries.length - 1];
      }

      const activeChanged = setActiveTocLink(activeEntry.link);
      if (activeChanged) {
        keepActiveLinkInView(activeEntry.link);
      }

      updateVisibleProgressPath(activeEntry);
      return activeEntry;
    };

    const media = window.matchMedia("(min-width: 1280px)");

    const updateDockState = () => {
      const wasDocked = floatingToc.classList.contains("is-docked-left");
      const shouldDock = media.matches;

      floatingToc.classList.toggle("is-docked-left", shouldDock);
      placeholder.hidden = true;
      placeholder.style.height = "";

      return wasDocked !== shouldDock;
    };

    updateDockState();
    rebuildTocProgressPath();
    updateActiveSection();

    if (article.dataset.tocDockListenersAttached === "true") return;
    article.dataset.tocDockListenersAttached = "true";

    let frame = 0;
    const updateTocOnScroll = () => {
      if (frame) return;
      frame = window.requestAnimationFrame(() => {
        frame = 0;
        const dockStateChanged = updateDockState();
        if (dockStateChanged) {
          rebuildTocProgressPath();
        }
        updateActiveSection();
      });
    };

    if ("IntersectionObserver" in window) {
      const headingEntryById = new Map(
        headingEntries.map(entry => [entry.heading.id, entry])
      );

      const headingObserver = new IntersectionObserver(
        observerEntries => {
          let hasChanges = false;

          for (const observerEntry of observerEntries) {
            if (!(observerEntry.target instanceof HTMLElement)) continue;

            const linkedEntry = headingEntryById.get(observerEntry.target.id);
            if (!linkedEntry) continue;

            if (linkedEntry.isIntersecting !== observerEntry.isIntersecting) {
              linkedEntry.isIntersecting = observerEntry.isIntersecting;
              hasChanges = true;
            }
          }

          if (hasChanges) {
            updateTocOnScroll();
          }
        },
        {
          rootMargin: "-20% 0px -65% 0px",
          threshold: [0, 1],
        }
      );

      for (const entry of headingEntries) {
        headingObserver.observe(entry.heading);
      }
    }

    const handleResize = () => {
      rebuildTocProgressPath();
      updateTocOnScroll();
    };

    window.addEventListener("scroll", updateTocOnScroll, { passive: true });
    window.addEventListener("resize", handleResize);
    floatingToc.addEventListener("scroll", updateActiveSection, { passive: true });
    media.addEventListener("change", handleResize);

    if (document.fonts?.ready) {
      document.fonts.ready.then(handleResize).catch(() => {});
    }
  }

  /** Adds "back to citation" links in bibliography entries. */
  function getSessionItem(key) {
    try {
      return window.sessionStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function setSessionItem(key, value) {
    try {
      window.sessionStorage.setItem(key, value);
    } catch {
      // Ignore storage failures (privacy mode / disabled storage).
    }
  }

  /** Converts bare URLs in bibliography entries into clickable links. */
  function linkifyReferenceUrls() {
    const referencesRoot = document.getElementById("refs");
    if (!(referencesRoot instanceof HTMLElement)) return;

    const urlPattern = /\b(?:https?:\/\/|www\.)[^\s<>"'`]+/gi;

    const trimTrailingPunctuation = rawUrl => {
      let url = rawUrl;
      let trailingText = "";

      while (/[.,;:!?]/.test(url.at(-1) ?? "")) {
        trailingText = `${url.at(-1)}${trailingText}`;
        url = url.slice(0, -1);
      }

      const bracketPairs = [
        ["(", ")"],
        ["[", "]"],
        ["{", "}"],
      ];

      for (const [opening, closing] of bracketPairs) {
        while (
          url.endsWith(closing) &&
          url.split(opening).length < url.split(closing).length
        ) {
          trailingText = `${closing}${trailingText}`;
          url = url.slice(0, -1);
        }
      }

      return { url, trailingText };
    };

    const createLink = urlText => {
      const link = document.createElement("a");
      link.href = urlText.toLowerCase().startsWith("www.")
        ? `https://${urlText}`
        : urlText;
      link.target = "_blank";
      link.rel = "noopener noreferrer";
      link.dataset.externalLink = "";
      link.textContent = urlText;
      return link;
    };

    const processTextNode = textNode => {
      const value = textNode.nodeValue ?? "";
      urlPattern.lastIndex = 0;
      if (!urlPattern.test(value)) return;

      urlPattern.lastIndex = 0;
      const fragment = document.createDocumentFragment();
      let lastIndex = 0;
      let match;

      while ((match = urlPattern.exec(value)) !== null) {
        const matchStart = match.index;
        const matchedUrl = match[0];

        if (matchStart > lastIndex) {
          fragment.appendChild(
            document.createTextNode(value.slice(lastIndex, matchStart))
          );
        }

        const { url, trailingText } = trimTrailingPunctuation(matchedUrl);

        if (url.length > 0) {
          fragment.appendChild(createLink(url));
        } else {
          fragment.appendChild(document.createTextNode(matchedUrl));
        }

        if (trailingText.length > 0) {
          fragment.appendChild(document.createTextNode(trailingText));
        }

        lastIndex = matchStart + matchedUrl.length;
      }

      if (lastIndex < value.length) {
        fragment.appendChild(document.createTextNode(value.slice(lastIndex)));
      }

      textNode.replaceWith(fragment);
    };

    const containers = Array.from(
      referencesRoot.querySelectorAll(".csl-right-inline")
    );

    if (!containers.length) {
      containers.push(referencesRoot);
    }

    for (const container of containers) {
      const walker = document.createTreeWalker(
        container,
        NodeFilter.SHOW_TEXT,
        {
          acceptNode(node) {
            if (!(node instanceof Text)) return NodeFilter.FILTER_REJECT;
            const value = node.nodeValue ?? "";
            if (!value.trim()) return NodeFilter.FILTER_REJECT;

            const parentElement = node.parentElement;
            if (
              parentElement &&
              parentElement.closest("a, code, pre, script, style")
            ) {
              return NodeFilter.FILTER_REJECT;
            }

            return NodeFilter.FILTER_ACCEPT;
          },
        }
      );

      const textNodes = [];
      let currentNode = walker.nextNode();
      while (currentNode) {
        textNodes.push(currentNode);
        currentNode = walker.nextNode();
      }

      for (const textNode of textNodes) {
        processTextNode(textNode);
      }
    }
  }

  function addCitationBackLinks() {
    const citationSpans = Array.from(
      document.querySelectorAll("span[id^='citation--']")
    );
    if (!citationSpans.length) return;

    const bibToCitationIds = new Map();

    for (const citationSpan of citationSpans) {
      const citationId = citationSpan.getAttribute("id");
      if (!citationId) continue;

      const bibLinks = Array.from(
        citationSpan.querySelectorAll("a[href^='#bib-']")
      );

      for (const bibLink of bibLinks) {
        const bibHref = bibLink.getAttribute("href");
        const bibId = bibHref?.slice(1);
        if (!bibId) continue;

        const citationIds = bibToCitationIds.get(bibId) ?? [];
        if (!citationIds.includes(citationId)) {
          citationIds.push(citationId);
          bibToCitationIds.set(bibId, citationIds);
        }

        if (!bibLink.dataset.returnHooked) {
          bibLink.dataset.returnHooked = "true";
          bibLink.addEventListener("click", () => {
            setSessionItem(`citation-return:${bibId}`, citationId);
            const backLink = document
              .getElementById(bibId)
              ?.querySelector(".citation-back-link");
            if (backLink) backLink.setAttribute("href", `#${citationId}`);
          });
        }
      }
    }

    for (const [bibId, citationIds] of bibToCitationIds.entries()) {
      const bibEntry = document.getElementById(bibId);
      if (!bibEntry || !citationIds.length) continue;

      const targetContainer =
        bibEntry.querySelector(".csl-right-inline") || bibEntry;
      targetContainer.querySelector(".citation-back-link")?.remove();

      const storedCitationId = getSessionItem(`citation-return:${bibId}`);
      const returnCitationId =
        storedCitationId && citationIds.includes(storedCitationId)
          ? storedCitationId
          : citationIds[0];

      const backLink = document.createElement("a");
      backLink.className = "citation-back-link";
      backLink.href = `#${returnCitationId}`;
      backLink.setAttribute("aria-label", "Back to citation");
      backLink.textContent = "↩";
      targetContainer.appendChild(backLink);
    }
  }

  /** Renders `_aside_:` footnotes as margin notes on wide screens. */
  function addMarginFootnotes() {
    const article = document.getElementById("article");
    if (!article) return;

    // Make reruns idempotent during client-side navigations.
    article.querySelectorAll(".margin-footnote").forEach(note => note.remove());
    article.classList.remove("has-margin-footnotes", "all-footnotes-as-margin");

    const footnotesSection = article.querySelector("section[data-footnotes]");
    if (!footnotesSection) return;

    footnotesSection
      .querySelectorAll("li.is-margin-footnote-source")
      .forEach(node => node.classList.remove("is-margin-footnote-source"));

    const footnotesById = new Map();
    for (const footnote of Array.from(
      footnotesSection.querySelectorAll("li[id]")
    )) {
      footnotesById.set(footnote.id, footnote);
    }

    let marginNotesAdded = 0;
    const marginSourceIds = new Set();
    const references = Array.from(
      article.querySelectorAll("a[data-footnote-ref][href^='#']")
    );

    for (const reference of references) {
      const footnoteId = reference.getAttribute("href")?.slice(1);
      if (!footnoteId) continue;

      const sourceFootnote = footnotesById.get(footnoteId);
      if (!sourceFootnote) continue;

      // Margin-note eligibility: definition starts with `_aside_:`.
      const firstParagraph = sourceFootnote.querySelector("p");
      const firstParagraphText =
        firstParagraph?.textContent?.trim().toLowerCase() ?? "";
      const isAsideFootnote = /^aside\s*:/.test(firstParagraphText);
      if (!isAsideFootnote) continue;

      sourceFootnote.classList.add("is-margin-footnote-source");
      marginSourceIds.add(footnoteId);

      const marginNote = document.createElement("aside");
      marginNote.className = "margin-footnote";
      marginNote.id = `margin-note-${footnoteId}-${marginNotesAdded + 1}`;

      // Clone source content and strip navigation-only back links.
      const contentClone = sourceFootnote.cloneNode(true);
      contentClone
        .querySelectorAll("a[data-footnote-backref]")
        .forEach(backRef => backRef.remove());
      contentClone
        .querySelectorAll("[id]")
        .forEach(node => node.removeAttribute("id"));

      // Remove the leading `_aside_:` label in rendered margin notes.
      const clonedFirstParagraph = contentClone.querySelector("p");
      if (clonedFirstParagraph) {
        const leadingElement = clonedFirstParagraph.firstElementChild;
        if (
          leadingElement?.tagName.toLowerCase() === "em" &&
          leadingElement.textContent?.trim().toLowerCase() === "aside"
        ) {
          leadingElement.remove();
        }

        const firstTextNode = Array.from(clonedFirstParagraph.childNodes).find(
          node => node.nodeType === Node.TEXT_NODE
        );
        if (firstTextNode) {
          firstTextNode.textContent = (
            firstTextNode.textContent ?? ""
          ).replace(/^\s*aside\s*:\s*/i, "").replace(/^\s*:\s*/, "");
          if (firstTextNode.textContent.trim() === "") {
            firstTextNode.remove();
          }
        }
      }

      while (contentClone.firstChild) {
        marginNote.appendChild(contentClone.firstChild);
      }

      const insertionPoint = reference.closest("sup") ?? reference;
      insertionPoint.classList.add("is-margin-footnote-ref");
      reference.classList.add("is-margin-footnote-ref-link");
      reference.textContent = "^";
      insertionPoint.insertAdjacentElement("afterend", marginNote);
      reference.dataset.marginNoteId = marginNote.id;

      if (!reference.dataset.marginNoteHooked) {
        reference.dataset.marginNoteHooked = "true";
        reference.addEventListener("click", event => {
          if (!window.matchMedia("(min-width: 900px)").matches) return;

          const marginNoteId = reference.dataset.marginNoteId;
          if (!marginNoteId) return;

          const linkedNote = article.querySelector(`#${marginNoteId}`);
          if (!linkedNote) return;

          event.preventDefault();
          linkedNote.classList.add("margin-footnote-active");
          linkedNote.scrollIntoView({ behavior: "smooth", block: "nearest" });
          window.setTimeout(
            () => linkedNote.classList.remove("margin-footnote-active"),
            800
          );
        });
      }

      marginNotesAdded += 1;
    }

    if (marginNotesAdded > 0) {
      article.classList.add("has-margin-footnotes");
      if (marginSourceIds.size === footnotesById.size) {
        article.classList.add("all-footnotes-as-margin");
      }
    }
  }

  /** Converts ANSI escape sequences in notebook output cells to styled HTML. */
  function renderAnsiCellOutput() {
    const ANSI_16_COLORS = [
      "#000000",
      "#cd0000",
      "#00cd00",
      "#cdcd00",
      "#0000ee",
      "#cd00cd",
      "#00cdcd",
      "#e5e5e5",
      "#7f7f7f",
      "#ff0000",
      "#00ff00",
      "#ffff00",
      "#5c5cff",
      "#ff00ff",
      "#00ffff",
      "#ffffff",
    ];

    const escapeHtml = text =>
      text
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");

    const ansi256ToCssColor = index => {
      if (!Number.isInteger(index) || index < 0 || index > 255) return null;
      if (index < 16) return ANSI_16_COLORS[index];

      if (index >= 232) {
        const level = 8 + (index - 232) * 10;
        return `rgb(${level}, ${level}, ${level})`;
      }

      const colorIndex = index - 16;
      const r = Math.floor(colorIndex / 36);
      const g = Math.floor((colorIndex % 36) / 6);
      const b = colorIndex % 6;
      const toChannel = value => (value === 0 ? 0 : value * 40 + 55);

      return `rgb(${toChannel(r)}, ${toChannel(g)}, ${toChannel(b)})`;
    };

    const applyAnsiCodes = (state, codeString) => {
      const rawCodes = codeString.length > 0 ? codeString.split(";") : ["0"];
      const codes = rawCodes.map(code => {
        const parsedCode = Number(code);
        return Number.isFinite(parsedCode) ? parsedCode : 0;
      });

      const resetState = () => {
        state.fg = null;
        state.bg = null;
        state.bold = false;
        state.italic = false;
        state.underline = false;
        state.inverse = false;
      };

      for (let index = 0; index < codes.length; index += 1) {
        const code = codes[index];

        if (code === 0) {
          resetState();
          continue;
        }
        if (code === 1) {
          state.bold = true;
          continue;
        }
        if (code === 3) {
          state.italic = true;
          continue;
        }
        if (code === 4) {
          state.underline = true;
          continue;
        }
        if (code === 7) {
          state.inverse = true;
          continue;
        }
        if (code === 22) {
          state.bold = false;
          continue;
        }
        if (code === 23) {
          state.italic = false;
          continue;
        }
        if (code === 24) {
          state.underline = false;
          continue;
        }
        if (code === 27) {
          state.inverse = false;
          continue;
        }
        if (code === 39) {
          state.fg = null;
          continue;
        }
        if (code === 49) {
          state.bg = null;
          continue;
        }
        if (code >= 30 && code <= 37) {
          state.fg = ANSI_16_COLORS[code - 30];
          continue;
        }
        if (code >= 90 && code <= 97) {
          state.fg = ANSI_16_COLORS[code - 90 + 8];
          continue;
        }
        if (code >= 40 && code <= 47) {
          state.bg = ANSI_16_COLORS[code - 40];
          continue;
        }
        if (code >= 100 && code <= 107) {
          state.bg = ANSI_16_COLORS[code - 100 + 8];
          continue;
        }
        if (code === 38 || code === 48) {
          const isForeground = code === 38;
          const mode = codes[index + 1];
          if (mode === 5) {
            const paletteIndex = codes[index + 2];
            const color = ansi256ToCssColor(paletteIndex);
            if (color) {
              if (isForeground) {
                state.fg = color;
              } else {
                state.bg = color;
              }
            }
            index += 2;
            continue;
          }
          if (mode === 2) {
            const r = codes[index + 2];
            const g = codes[index + 3];
            const b = codes[index + 4];
            if (
              Number.isInteger(r) &&
              Number.isInteger(g) &&
              Number.isInteger(b) &&
              r >= 0 &&
              g >= 0 &&
              b >= 0 &&
              r <= 255 &&
              g <= 255 &&
              b <= 255
            ) {
              const color = `rgb(${r}, ${g}, ${b})`;
              if (isForeground) {
                state.fg = color;
              } else {
                state.bg = color;
              }
            }
            index += 4;
            continue;
          }
        }
      }
    };

    const wrapStyledText = (text, state) => {
      if (!text) return "";

      const escapedText = escapeHtml(text);
      let fg = state.fg;
      let bg = state.bg;

      if (state.inverse) {
        [fg, bg] = [bg, fg];
      }

      const styles = [];
      if (fg) styles.push(`color:${fg}`);
      if (bg) styles.push(`background-color:${bg}`);
      if (state.bold) styles.push("font-weight:700");
      if (state.italic) styles.push("font-style:italic");
      if (state.underline) styles.push("text-decoration:underline");

      if (styles.length === 0) return escapedText;
      return `<span style="${styles.join(";")}">${escapedText}</span>`;
    };

    const ansiToHtml = input => {
      const state = {
        fg: null,
        bg: null,
        bold: false,
        italic: false,
        underline: false,
        inverse: false,
      };

      const ansiRegex = /\u001b\[([0-9;]*)m/g;
      let html = "";
      let lastIndex = 0;
      let match = ansiRegex.exec(input);

      while (match) {
        const plainText = input.slice(lastIndex, match.index);
        html += wrapStyledText(plainText, state);
        applyAnsiCodes(state, match[1] ?? "");

        lastIndex = ansiRegex.lastIndex;
        match = ansiRegex.exec(input);
      }

      html += wrapStyledText(input.slice(lastIndex), state);
      return html;
    };

    const ansiLines = document.querySelectorAll(
      ".cell-output pre[data-language='plaintext'] code .line"
    );

    for (const line of ansiLines) {
      if (!(line instanceof HTMLElement)) continue;
      if (line.dataset.ansiParsed === "true") continue;

      const rawText = line.textContent ?? "";
      if (!rawText.includes("\u001b[")) continue;

      line.innerHTML = ansiToHtml(rawText);
      line.dataset.ansiParsed = "true";
    }
  }

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      if (codeBlock.querySelector(":scope > button.copy-code")) continue;

      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";
      wrapper.className = "group";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium opacity-0 pointer-events-none transition-opacity duration-150 group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:opacity-100 group-focus-within:pointer-events-auto`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }

  function setupGiscus() {
    const giscusContainer = document.querySelector(".giscus");
    if (!(giscusContainer instanceof HTMLElement)) return;
    if (giscusContainer.dataset.giscusInitialized === "true") return;

    const giscusScript = document.createElement("script");
    giscusScript.src = "https://giscus.app/client.js";
    giscusScript.setAttribute("data-repo", "kdheepak/kdheepak.github.io");
    giscusScript.setAttribute(
      "data-repo-id",
      "MDEwOlJlcG9zaXRvcnk1MTIwOTcwMA=="
    );
    giscusScript.setAttribute("data-category", "Comments");
    giscusScript.setAttribute("data-category-id", "DIC_kwDOAw1l5M4CU810");
    giscusScript.setAttribute("data-mapping", "pathname");
    giscusScript.setAttribute("data-strict", "0");
    giscusScript.setAttribute("data-reactions-enabled", "1");
    giscusScript.setAttribute("data-emit-metadata", "0");
    giscusScript.setAttribute("data-input-position", "bottom");
    giscusScript.setAttribute("data-theme", "light");
    giscusScript.setAttribute("data-lang", "en");
    giscusScript.setAttribute("data-loading", "lazy");
    giscusScript.crossOrigin = "anonymous";
    giscusScript.async = true;

    giscusContainer.appendChild(giscusScript);
    giscusContainer.dataset.giscusInitialized = "true";
  }

  function initializePostPage() {
    const article = document.getElementById("article");
    if (!(article instanceof HTMLElement)) return;
    if (article.dataset.postEnhancementsInitialized === "true") return;
    article.dataset.postEnhancementsInitialized = "true";

    createProgressBar();
    updateScrollProgress();
    setupDockingToc();

    try {
      linkifyReferenceUrls();
      addCitationBackLinks();
    } catch {
      // Keep the rest of post enhancements working even if citation linking fails.
    }

    addMarginFootnotes();
    renderAnsiCellOutput();
    attachCopyButtons();
    setupGiscus();
  }

  initializePostPage();
  document.addEventListener("astro:page-load", initializePostPage, { once: true });

  /* Go to page start after page swap unless navigating to a hash target. */
  if (!window.__kdPostAfterSwapScrollHooked) {
    document.addEventListener("astro:after-swap", () => {
      if (!document.getElementById("article")) return;

      const hash = window.location.hash;
      if (!hash || hash === "#") {
        window.scrollTo({ left: 0, top: 0, behavior: "instant" });
        return;
      }

      const targetId = decodeURIComponent(hash.slice(1));
      const targetElement = document.getElementById(targetId);
      if (!targetElement) return;

      requestAnimationFrame(() => {
        targetElement.scrollIntoView({ block: "start", inline: "nearest" });
      });
    });
    window.__kdPostAfterSwapScrollHooked = true;
  }
</script>
