---
import "@pagefind/default-ui/css/ui.css";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const backUrl = SITE.showBackButton ? `${Astro.url.pathname}` : "/";
---

<Layout title="Search">
  <Header />
  <Main pageTitle="Search">
    <div id="pagefind-search" transition:persist data-backurl={backUrl}></div>
  </Main>
  <Footer />
</Layout>

<script>
  let searchResultsObserver: MutationObserver | null = null;

  function decorateSearchResultDates(root: ParentNode) {
    const results = root.querySelectorAll(".pagefind-ui__result");

    for (const result of results) {
      if (!(result instanceof HTMLElement)) continue;

      const title = result.querySelector(".pagefind-ui__result-title");
      if (!(title instanceof HTMLElement)) continue;
      if (title.querySelector(".pagefind-ui__result-date")) continue;

      const dateTag = result.querySelector(
        '.pagefind-ui__result-tag[data-pagefind-ui-meta="date"]'
      );
      if (!(dateTag instanceof HTMLElement)) continue;

      const rawDateText = dateTag.textContent?.trim() ?? "";
      const dateText = rawDateText.replace(/^date:\s*/i, "").trim();
      if (!dateText) continue;

      title.classList.add("pagefind-ui__result-title-row");

      const dateSpan = document.createElement("span");
      dateSpan.className = "pagefind-ui__result-date";
      dateSpan.textContent = dateText;
      title.append(dateSpan);

      dateTag.remove();
      const tagsList = result.querySelector(".pagefind-ui__result-tags");
      if (tagsList instanceof HTMLElement && tagsList.children.length === 0) {
        tagsList.remove();
      }
    }
  }

  function initSearch() {
    const pageFindSearch: HTMLElement | null =
      document.querySelector("#pagefind-search");

    if (!pageFindSearch) return;

    searchResultsObserver?.disconnect();
    searchResultsObserver = null;

    const params = new URLSearchParams(window.location.search);

    const onIdle = window.requestIdleCallback || (cb => setTimeout(cb, 1));

    onIdle(async () => {
      try {
        // @ts-expect-error — Missing types for @pagefind/default-ui package.
        const { PagefindUI } = await import("@pagefind/default-ui");

        // Display warning in dev mode
        if (import.meta.env.DEV) {
          pageFindSearch.innerHTML = `
              <div class="bg-muted/75 rounded p-4 space-y-4 mb-4">
                <p><strong>DEV mode Warning! </strong>You need to build the project at least once to see the search results during development.</p>
                <code class="block bg-black text-white px-2 py-1 rounded">pnpm run build</code>
              </div>
            `;
        }

        // Init pagefind ui
        const search = new PagefindUI({
          element: "#pagefind-search",
          bundlePath: "/pagefind/",
          showImages: false,
          showSubResults: true,
          processTerm: function (term: string) {
            if (term.trim()) {
              params.set("q", term);
            } else {
              params.delete("q");
            }

            const queryString = params.toString();
            history.replaceState(
              history.state,
              "",
              queryString ? `?${queryString}` : window.location.pathname
            );

            const backUrl = pageFindSearch?.dataset?.backurl ?? window.location.pathname;
            const sessionBackUrl = queryString
              ? `${backUrl}?${queryString}`
              : backUrl;
            sessionStorage.setItem("backUrl", sessionBackUrl);

            return term;
          },
        });

        searchResultsObserver = new MutationObserver(() => {
          decorateSearchResultDates(pageFindSearch);
        });
        searchResultsObserver.observe(pageFindSearch, {
          childList: true,
          subtree: true,
        });
        decorateSearchResultDates(pageFindSearch);

        // If search param exists (eg: search?q=astro), trigger search
        const query = params.get("q");
        if (query) {
          search.triggerSearch(query);
        }

        // Reset search param if search input is cleared
        const searchInput = document.querySelector(
          ".pagefind-ui__search-input"
        ) as HTMLInputElement | null;
        const clearButton = document.querySelector(".pagefind-ui__search-clear");

        function resetSearchParam() {
          if (!searchInput || searchInput.value.trim() !== "") return;
          params.delete("q");
          history.replaceState(history.state, "", window.location.pathname);
        }

        searchInput?.addEventListener("input", resetSearchParam);
        clearButton?.addEventListener("click", () => {
          // Let Pagefind clear the input first, then normalize URL.
          queueMicrotask(resetSearchParam);
        });
      } catch (error) {
        console.error("Failed to initialize search", error);
        pageFindSearch.innerHTML = `
          <div class="bg-muted/75 rounded p-4">
            <p><strong>Search is temporarily unavailable.</strong></p>
          </div>
        `;
      }
    });
  }

  document.addEventListener("astro:after-swap", () => {
    const pagefindSearch = document.querySelector("#pagefind-search");

    // if pagefind search form already exists, don't initialize search component
    if (pagefindSearch && pagefindSearch.querySelector("form")) return;

    initSearch();
  });
  document.addEventListener("astro:before-swap", () => {
    searchResultsObserver?.disconnect();
    searchResultsObserver = null;
  });
  initSearch();
</script>

<style is:global>
  #pagefind-search {
    --pagefind-ui-font: var(--font-app);
    --pagefind-ui-text: var(--foreground);
    --pagefind-ui-background: var(--background);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-tag: var(--background);
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;

    form::before {
      background-color: var(--foreground);
    }

    input {
      font-weight: 400;
      border: 1px solid var(--border);
    }

    input:focus-visible {
      outline: 1px solid var(--accent);
    }

    .pagefind-ui__result-title a {
      color: var(--accent);
      outline-offset: 1px;
      outline-color: var(--accent);
      text-decoration-style: dashed;
      text-underline-offset: 4px;
    }

    .pagefind-ui__result-title a:focus-visible,
    .pagefind-ui__search-clear:focus-visible {
      text-decoration-line: none;
      outline-width: 2px;
      outline-style: dashed;
    }

    .pagefind-ui__result-title-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: baseline;
      width: 100%;
    }

    .pagefind-ui__result-date {
      opacity: 0.8;
      font-size: 0.9rem;
      font-weight: 400;
      white-space: nowrap;
    }

    .pagefind-ui__result:last-of-type {
      border-bottom: 0;
    }

    .pagefind-ui__result-nested .pagefind-ui__result-link:before {
      font-family: system-ui;
    }

    @media (max-width: 40rem) {
      .pagefind-ui__result-title-row {
        grid-template-columns: 1fr;
        gap: 0.25rem;
      }
    }
  }
</style>
