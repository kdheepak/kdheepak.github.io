---
import { Icon } from "astro-icon/components";
import Typewriter from "astro-typewriter";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ObfuscatedEmail from "@/components/ObfuscatedEmail.astro";
import { SOCIALS } from "@/constants";

const CONTACT_SOCIAL_NAMES = new Set(["Mail", "GitHub", "LinkedIn"]);
const CONTACT_SOCIALS = SOCIALS.filter(({ name }) =>
  CONTACT_SOCIAL_NAMES.has(name),
);

const getMailtoAddress = (href: string): string | null => {
  if (!href.startsWith("mailto:")) return null;

  const address = href.slice("mailto:".length).split("?")[0];
  return address || null;
};

const contactLinkClass =
  "group inline-flex items-center gap-[0.38rem] rounded-full border border-border px-3 py-1.5 leading-none transition-colors hover:border-accent/60 hover:text-accent";
const contactIconClass =
  "inline-block size-[1.02em] fill-transparent stroke-current stroke-2 opacity-90 transition-transform group-hover:rotate-6 group-hover:fill-transparent";
---

<Layout title="kdheepak.com">
  <Header />
  <main id="main-content" data-layout="index" class="app-layout pb-8 sm:pb-0">
    <section
      id="hero"
      class:list={[
        "border-b border-border py-6 sm:py-8",
        "grid gap-5 sm:gap-6 md:grid-cols-[1fr_auto] md:items-center md:gap-10",
      ]}
    >
      <picture class="order-1 mx-auto block md:order-2 md:mx-0 md:justify-self-end">
        <img
          src="https://avatars.githubusercontent.com/u/1813121?v=4"
          alt="Dheepak Krishnamurthy"
          width="160"
          height="160"
          loading="eager"
          class="h-36 w-36 rounded-full border-2 border-border object-cover sm:h-44 sm:w-44"
        />
      </picture>

      <div class="order-2 md:order-1">
        <h1 class="text-3xl leading-tight font-bold sm:text-5xl">Hello!</h1>

        <p class="mt-3 text-base leading-relaxed sm:mt-4 sm:text-lg">
          I'm a{" "}
          <Typewriter
            class="inline-block min-w-[13ch] font-semibold text-[#1481b8] sm:min-w-[16ch]"
            messages={[
              "research engineer.",
              "software developer.",
              "bicycle enthusiast.",
            ]}
            writeSpeed={70}
            deleteSpeed={36}
            waitWritten={1500}
            waitDeleted={420}
          />
        </p>

        <p class="mt-4 max-w-prose leading-relaxed text-pretty">
          I have experience running energy system models and simulations, such as
          transmission production cost models and power distribution system analyses,
          and have developed bespoke models for energy system analysis. I'm
          proficient with Python, Julia, Rust, and Javascript, and am well versed in
          scientific data analysis and extract-transform-load workflows. I also enjoy
          working on open source projects and learning new things.
        </p>
      </div>
    </section>

    <section class="py-8 sm:pt-10 sm:pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">Contact</h2>
      <p class="mt-2">You can contact me through:</p>

      <ul
        class="mt-4 flex flex-wrap gap-2 text-[0.95rem] sm:gap-3"
        aria-label="Contact links"
      >
        {
          CONTACT_SOCIALS.map(social => {
            const emailAddress = getMailtoAddress(social.href);

            return emailAddress ? (
              <li>
                <ObfuscatedEmail
                  email={emailAddress}
                  class={contactLinkClass}
                  title={social.linkTitle}
                >
                  <Icon class={contactIconClass} name={social.icon} aria-hidden="true" />
                  Email
                </ObfuscatedEmail>
              </li>
            ) : (
              <li>
                <a
                  class={contactLinkClass}
                  href={social.href}
                  title={social.linkTitle}
                >
                  <Icon class={contactIconClass} name={social.icon} aria-hidden="true" />
                  {social.name}
                </a>
              </li>
            );
          })
        }
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
